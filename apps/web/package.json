{
  "name": "@tinysa/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "cloudflare:login": "wrangler login",
    "deploy:cloudflare": "npm run build && wrangler deploy --name atomizer --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@tinysa/agent": "*",
    "@tinysa/analysis": "*",
    "@tinysa/contracts": "*",
    "lucide-react": "1.25.0",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.46.0",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-rsc": "0.5.28",
    "jsdom": "29.1.1",
    "react-server-dom-webpack": "19.2.8",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.113.0"
  }
}
