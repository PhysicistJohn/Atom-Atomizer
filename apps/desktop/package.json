{
  "name": "@tinysa/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:main && vite build",
    "build:main": "tsup src/main/main.ts --format esm --out-dir dist/main --external electron --external serialport && tsup src/main/preload.ts --format cjs --out-dir dist/main --external electron",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@tinysa/agent": "*",
    "@tinysa/analysis": "*",
    "@tinysa/contracts": "*",
    "@tinysa/device": "*",
    "dotenv": "17.4.2",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.3",
    "cross-env": "10.1.0",
    "electron": "43.1.0",
    "jsdom": "29.1.1",
    "vite": "8.1.4",
    "wait-on": "9.0.3"
  }
}
