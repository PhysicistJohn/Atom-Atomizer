{
  "name": "@tinysa/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:main && vite build",
    "build:main": "tsup src/main/main.ts --format esm --target node22 --out-dir dist/main --external electron --external serialport && tsup src/main/preload.ts --format cjs --target node22 --out-dir dist/main --external electron",
    "package:prepare": "npm --prefix ../.. run build",
    "package:mac": "npm run package:prepare && electron-builder --mac dmg zip",
    "package:win": "npm run package:prepare && electron-builder --win nsis portable",
    "package:linux": "npm run package:prepare && electron-builder --linux AppImage",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@atomos/dsp": "file:../../../Atom-DSP",
    "@tinysa/agent": "*",
    "@tinysa/analysis": "*",
    "@tinysa/contracts": "*",
    "@tinysa/device": "*",
    "@tinysa/instrument-runtime": "*",
    "dotenv": "17.4.2",
    "lucide-react": "1.25.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "ws": "8.21.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "^9.2.4",
    "cross-env": "10.1.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "vite": "8.1.5",
    "wait-on": "9.1.0"
  },
  "build": {
    "appId": "com.physicistjohn.atomizer",
    "productName": "Atomizer",
    "directories": {
      "output": "../../release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/@serialport/**",
      "node_modules/serialport/**"
    ],
    "files": [
      "dist/main/**",
      "dist/renderer/**",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": "-",
      "target": ["dmg"]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "target": ["AppImage"]
    }
  }
}
