{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tinysa/contracts": ["packages/contracts/src/index.ts"],
      "@tinysa/instrument-runtime": ["packages/instrument-runtime/src/index.ts"],
      "@tinysa/signal-lab-driver": ["packages/signal-lab-driver/src/index.ts"],
      "@tinysa/device": ["packages/tinysa/src/index.ts"],
      "@tinysa/test-device": ["packages/test-device/src/index.ts"],
      "@tinysa/analysis": ["packages/analysis/src/index.ts"],
      "@tinysa/agent": ["packages/agent/src/index.ts"]
    },
    "declaration": true,
    "sourceMap": true
  }
}
